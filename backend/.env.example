# Required: Gemini API key for the cleaning stage
GEMINI_API_KEY=your-key-here

# Optional: MongoDB password for GTIN stage (SALT database lookup)
MONGODB_PASSWORD=

# Optional: Perplexity API key for GTIN fallback
PERPLEXITY_API_KEY=

# Max upload size in MB
MAX_UPLOAD_MB=50

# Job TTL in hours (results deleted after this)
JOB_TTL_HOURS=24

# Max concurrent pipeline jobs
MAX_CONCURRENT_JOBS=3

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
